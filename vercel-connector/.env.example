WEBHOOK_BEARER_SECRET=replace_me
FCM_TOKEN_SYNC_BEARER=replace_me
FIREBASE_PROJECT_ID=ontacoche
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ontacoche.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
FCM_TOKEN_COLLECTION=fcm_tokens
APP_READ_BEARER=
DEFAULT_DEVICE_ID=009590067804
DEVICE_STATE_COLLECTION=device_last_state
STATE_HISTORY_COLLECTION=device_state_history
ALERTS_COLLECTION=device_alerts
STORE_STATE_HISTORY=true
PUSH_ON_COMMUNICATION_ACTIVE=false
LOG_LEVEL=info

# trips runtime
TRIPS_COLLECTION=device_trips
TRIP_RUNTIME_COLLECTION=device_trip_runtime
TRIP_INACTIVITY_SEC=600
TRIP_MIN_DISTANCE_M=200
TRIP_MIN_SPEED_KPH=8
TRIP_MIN_MOVE_DISTANCE_M=50

# geofence transition filtering
GEOFENCE_ALLOWED_REASON_CODES=20,2
GEOFENCE_MAX_RECALC_AGE_SEC=900

# geofence crud (app -> vercel -> flespi)
APP_WRITE_BEARER=
FLESPI_TOKEN=
FLESPI_GEOFENCE_CALC_ID=
FLESPI_BASE_URL=https://flespi.io
